        embedder,
        embeddings_file_path,
        store,
        last_results: Vec::new(),
        last_search_results: Vec::new(),
        rl,
        history_path,
        http_client: reqwest::Client::new(),
        prompt_history: Vec::new(),
        history_agent: Some(history_agent),
        prompts,
        doc_parsers,
        pdf_parser: pdf_parser,
        epub_parser: epub_parser,
    })
}

