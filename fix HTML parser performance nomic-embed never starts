        }

        match sub {
            "reset" => {
                self.prompts = SystemPrompts::default();
                println!("Prompts reset to defaults.");
            }
            "chat" => {
                let file = parts.next();
                let Some(file) = file else {
                    println!("Usage: /prompt chat <file>");
