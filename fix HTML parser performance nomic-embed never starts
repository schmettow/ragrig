                let Some(file) = file else {
                    println!("Usage: /prompt rewrite <file>");
                    return Ok(());
                };
                match self.prompts.load_rewrite_from_file(std::path::Path::new(file)) {
                    Ok(()) => println!("Rewrite prompt loaded from {}", file),
