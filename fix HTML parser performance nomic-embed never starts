/// Query Ollama's `/api/show` endpoint for the model's context length.
/// Falls back to 4096 on any failure (network, parse, unknown model, etc.).
///
/// The response looks like:
/// ```json
/// { "model_info": { "qwen2.context_length": "32768", … } }
/// ```
/// We scan all keys in `model_info` for one ending in `.context_length`.
async fn fetch_ollama_ctx_tokens(client: &reqwest::Client, model: &str) -> usize {
    let body = serde_json::json!({"name": model});
    let resp = match client
        .post("http://localhost:11434/api/show")
        .json(&body)
        .send()
        .await
    {
        Ok(r) => r,
        Err(e) => {
            eprintln!("[DEBUG] Ollama /api/show request failed: {}", e);
            return 4096;
        }
    };
    let json: serde_json::Value = match resp.json().await {
        Ok(v) => v,
        Err(e) => {
            eprintln!("[DEBUG] Ollama /api/show parse failed: {}", e);
            return 4096;
        }
    };
    // Look for any key ending in ".context_length" inside model_info.
    if let Some(info) = json.get("model_info").and_then(|v| v.as_object()) {
        for (key, val) in info {
            if key.ends_with(".context_length") {
                if let Some(n) = val.as_str().and_then(|s| s.parse::<usize>().ok()) {
                    eprintln!("[DEBUG] {} context window: {} tokens", model, n);
                    return n;
                }
                if let Some(n) = val.as_u64() {
                    let n = n as usize;
                    eprintln!("[DEBUG] {} context window: {} tokens", model, n);
                    return n;
                }
            }
        }
    }
    eprintln!("[DEBUG] Could not determine context length for {}; defaulting to 4096", model);
    4096
}

