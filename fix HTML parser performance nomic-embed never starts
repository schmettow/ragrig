    parsers.push(Box::new(epub_parser::EpubParser));
    parsers.push(Box::new(html_parser::HtmlParser));
    parsers.push(Box::new(docx_parser::DocxParser));
    parsers.push(Box::new(markdown_parser::MarkdownParser));

