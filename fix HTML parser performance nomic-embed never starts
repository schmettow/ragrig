            println!("  chat (no docs): {:.80}", self.prompts.chat_without_docs.trim());
            println!("  rewrite:        {:.80}", self.prompts.rewrite.trim());
            println!("Usage: /prompt chat|rewrite <file>  or  /prompt reset");
