        fn parse(&self, path: &Path) -> Result<String> {
            let doc = pdfsink_rs::open_pdf(path)
                .map_err(|e| anyhow!("pdfsink parse error: {}", e))?;

            let mut md = String::new();
            let pages = doc.pages();
            for (i, page) in pages.iter().enumerate() {
                if pages.len() > 1 {
                    md.push_str(&format!("# Page {}\n\n", i + 1));
                }
